{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist",
    "noImplicitAny": true,
    "stripInternal": true,
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "ES5",
    "jsx": "react",
    "allowSyntheticDefaultImports": true,
    "lib": ["es2017", "dom"],
    "types": ["jest", "react"]
  },
  "exclude": ["node_modules"]
}
