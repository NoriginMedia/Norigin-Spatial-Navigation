{
  "name": "@noriginmedia/norigin-spatial-navigation-core",
  "version": "3.0.0",
  "description": "Core spatial navigation logic for web and TV.",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
